# Files we don't want gcloud to upload with the function source.
# This file is standalone (no #!include:.gitignore) because the deploy
# script rsyncs shared/ into this directory at deploy time, and we need
# to make sure shared/ IS uploaded even though it's gitignored.

.gcloudignore
.git
.gitignore

__pycache__/
*.pyc
*.pyo

.env
.env.*

*.md

node_modules/
.DS_Store

deploy.sh

# Force-include the shared/ directory even if any of the above ignored it.
!shared/
